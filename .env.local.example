# Local development environment
# Copy to .env and fill in real values
# Run bolt locally first: yarn start:test

REACT_APP_HOST_URL=http://localhost:3003
REACT_APP_ARRAKIS_API_BASE=https://arrakis.team2realbrokerage.com
REACT_APP_YENTA_API_BASE=https://yenta.team2realbrokerage.com
REACT_APP_KEYMAKER_API_BASE=https://keymaker.team2realbrokerage.com
REACT_APP_LEO_API_BASE=https://leo.team2realbrokerage.com
REACT_APP_HERMES_API_BASE=https://hermes.team2realbrokerage.com

# Point your local frontend at team2 backends.
# Change *_API_BASE values to team1 if testing against team1 backend.
